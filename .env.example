# ── Telegram API (get from https://my.telegram.org) ──────
API_ID=12345678
API_HASH=your_api_hash_here

# ── Bot Token (get from @BotFather) ──────────────────────
BOT_TOKEN=123456789:ABCDefgh...

# ── Your Telegram User ID ─────────────────────────────────
OWNER_ID=123456789

# ── MongoDB Connection String ─────────────────────────────
DATABASE_URL=mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net

# ── Force Subscribe Channel ───────────────────────────────
# Channel ID (negative number, e.g. -1001234567890)
# Set to "0" to DISABLE force subscribe
FORCE_SUB_CHANNEL=-1001234567890

# ── File DB Channel ───────────────────────────────────────
# Private channel where all files are stored
# Bot MUST be admin with "Post Messages" permission
FILE_DB_CHANNEL=-1009876543210

# ── Log Channel (optional) ────────────────────────────────
LOG_CHANNEL=0
